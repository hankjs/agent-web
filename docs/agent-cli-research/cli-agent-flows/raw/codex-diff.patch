@@ -0,0 +1,52 @@
+#!/usr/bin/env node
+
+const {
+  listRequirements,
+  addRequirement,
+  toggleRequirement
+} = require('../src/requirements');
+
+function printRequirements(requirements) {
+  for (const requirement of requirements) {
+    const marker = requirement.completed ? 'x' : ' ';
+    console.log(`[${marker}] ${requirement.id} ${requirement.title}`);
+  }
+}
+
+function usage() {
+  console.log('Usage: reqs <list|add|toggle> [title|id]');
+}
+
+function main(argv) {
+  const [command, ...args] = argv;
+
+  try {
+    if (command === 'list') {
+      printRequirements(listRequirements());
+      return;
+    }
+
+    if (command === 'add') {
+      const title = args.join(' ');
+      const requirement = addRequirement(title);
+      console.log(`Added ${requirement.id}: ${requirement.title}`);
+      return;
+    }
+
+    if (command === 'toggle') {
+      const [id] = args;
+      const requirement = toggleRequirement(id);
+      const state = requirement.completed ? 'completed' : 'open';
+      console.log(`${requirement.id} is now ${state}.`);
+      return;
+    }
+
+    usage();
+    process.exitCode = 1;
+  } catch (error) {
+    console.error(error.message);
+    process.exitCode = 1;
+  }
+}
+
+main(process.argv.slice(2));
