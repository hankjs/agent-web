@@ -0,0 +1,86 @@
+const assert = require('node:assert/strict');
+const fs = require('node:fs');
+const os = require('node:os');
+const path = require('node:path');
+const test = require('node:test');
+
+const {
+  listRequirements,
+  addRequirement,
+  toggleRequirement
+} = require('../src/requirements');
+
+const sampleRequirements = [
+  {
+    id: 'REQ-001',
+    title: 'Capture stakeholder needs',
+    completed: false
+  },
+  {
+    id: 'REQ-002',
+    title: 'Define acceptance criteria',
+    completed: false
+  },
+  {
+    id: 'REQ-003',
+    title: 'Validate implementation coverage',
+    completed: true
+  }
+];
+
+function createRequirementsFile() {
+  const directory = fs.mkdtempSync(path.join(os.tmpdir(), 'reqs-test-'));
+  const filePath = path.join(directory, 'requirements.json');
+  fs.writeFileSync(filePath, `${JSON.stringify(sampleRequirements, null, 2)}\n`);
+  return { directory, filePath };
+}
+
+test('lists requirements from a requirements file', () => {
+  const { directory, filePath } = createRequirementsFile();
+
+  try {
+    assert.deepEqual(listRequirements(filePath), sampleRequirements);
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+});
+
+test('adds a requirement with the next id', () => {
+  const { directory, filePath } = createRequirementsFile();
+
+  try {
+    const requirement = addRequirement('Confirm launch checklist', filePath);
+    const requirements = listRequirements(filePath);
+
+    assert.deepEqual(requirement, {
+      id: 'REQ-004',
+      title: 'Confirm launch checklist',
+      completed: false
+    });
+    assert.equal(requirements.length, 4);
+    assert.deepEqual(requirements.at(-1), requirement);
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+});
+
+test('toggles a requirement completion state', () => {
+  const { directory, filePath } = createRequirementsFile();
+
+  try {
+    const requirement = toggleRequirement('REQ-001', filePath);
+    const requirements = listRequirements(filePath);
+
+    assert.deepEqual(requirement, {
+      id: 'REQ-001',
+      title: 'Capture stakeholder needs',
+      completed: true
+    });
+    assert.equal(requirements[0].completed, true);
+
+    const toggledAgain = toggleRequirement('REQ-001', filePath);
+    assert.equal(toggledAgain.completed, false);
+  } finally {
+    fs.rmSync(directory, { recursive: true, force: true });
+  }
+});
