@@ -0,0 +1,68 @@
+const fs = require('node:fs');
+const path = require('node:path');
+
+const defaultFilePath = path.join(__dirname, '..', 'requirements.json');
+
+function readRequirements(filePath = defaultFilePath) {
+  const content = fs.readFileSync(filePath, 'utf8');
+  return JSON.parse(content);
+}
+
+function writeRequirements(requirements, filePath = defaultFilePath) {
+  fs.writeFileSync(filePath, `${JSON.stringify(requirements, null, 2)}\n`);
+}
+
+function nextId(requirements) {
+  const highest = requirements.reduce((max, requirement) => {
+    const match = /^REQ-(\d+)$/.exec(requirement.id);
+    return match ? Math.max(max, Number(match[1])) : max;
+  }, 0);
+
+  return `REQ-${String(highest + 1).padStart(3, '0')}`;
+}
+
+function listRequirements(filePath = defaultFilePath) {
+  return readRequirements(filePath);
+}
+
+function addRequirement(title, filePath = defaultFilePath) {
+  if (!title || !title.trim()) {
+    throw new Error('Requirement title is required.');
+  }
+
+  const requirements = readRequirements(filePath);
+  const requirement = {
+    id: nextId(requirements),
+    title: title.trim(),
+    completed: false
+  };
+
+  requirements.push(requirement);
+  writeRequirements(requirements, filePath);
+
+  return requirement;
+}
+
+function toggleRequirement(id, filePath = defaultFilePath) {
+  if (!id || !id.trim()) {
+    throw new Error('Requirement id is required.');
+  }
+
+  const requirements = readRequirements(filePath);
+  const requirement = requirements.find((item) => item.id === id);
+
+  if (!requirement) {
+    throw new Error(`Requirement not found: ${id}`);
+  }
+
+  requirement.completed = !requirement.completed;
+  writeRequirements(requirements, filePath);
+
+  return requirement;
+}
+
+module.exports = {
+  listRequirements,
+  addRequirement,
+  toggleRequirement
+};
diff --git a/test/requirements.test.js b/test/requirements.test.js
new file mode 100644
index 0000000..d5c8349
--- /dev/null
